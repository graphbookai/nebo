FROM python:3.12-slim

# Hugging Face Spaces persistent volume mounts at /data. The daemon
# persists incoming network-mode events there via --save-files so runs
# survive Space restarts. The directory watcher (--logdir) is disabled
# because the Space's working directory is ephemeral — nothing else
# would ever write there.
ENV PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

${install_block}

# Hugging Face Spaces requires Docker apps to listen on port 7860 by
# default. We bind to 0.0.0.0 so the routed traffic reaches us.
EXPOSE 7860

CMD ["nebo", "serve", "--host", "0.0.0.0", "--port", "7860", "--save-files", "/data", "--no-local"]
